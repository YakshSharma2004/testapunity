{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/dev-.log",
          "rollingInterval": "Day",
          "restrictedToMinimumLevel": "Debug",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/demo-.log",
          "rollingInterval": "Day",
          "restrictedToMinimumLevel": "Information",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "Onnx": {
    "ModelPath": "models/intent-classifier.onnx",
    "InputNames": [
      "input_ids"
    ],
    "OutputNames": [
      "logits"
    ]
  },
  "Embeddings": {
    "Model": "mpnet",
    "Models": {
      "mpnet": {
        "ModelPath": "models/mpnet/model.onnx",
        "TokenizerPath": "models/mpnet/tokenizer.json",
        "MaxLen": 384
      },
      "multiqa": {
        "ModelPath": "models/multiqa/model.onnx",
        "TokenizerPath": "models/multiqa/tokenizer.json",
        "MaxLen": 384
      }
    }
  },
  "ApiCache": {
    "IntentTtlSeconds": 15,
    "LlmTtlSeconds": 60,
    "ModelVersion": "v1"
  },
  "Redis": {
    "InstanceName": "testapi1:"
  },
  "AllowedHosts": "*",
  "IntentClassification": {
    "TopK": 3,
    "MinConfidence": 0.45,
    "IncludeDebugNotes": true
  },
  "Progression": {
    "SessionTtlMinutes": 120,
    "ConfessionRequiredClues": [
      "elsa_email_draft",
      "payroll_report",
      "meeting_note",
      "entry_log",
      "pin_note",
      "cleanup_item",
      "weapon_found",
      "flash_drive"
    ]
  },
  "VectorStore": {
    "Provider": "SET_VIA_ENV"
  },
  "Qdrant": {
    "BaseUrl": "SET_VIA_ENV",
    "CollectionName": "SET_VIA_ENV",
    "ApiKey": ""
  },
  "Llm": {
    "Local": {
      "Enabled": true,
      "BaseUrl": "http://localhost:11434",
      "Model": "",
      "TimeoutMs": 120000,
      "Seed": 17,
      "MaxRecentExchanges": 4,
      "MaxLoreSnippets": 3,
      "MaxTimelineItems": 3,
      "MaxPublicStoryChars": 500,
      "MaxTruthSummaryChars": 500,
      "MaxRelationshipMemoryChars": 200
    },
    "Remote": {
      "Enabled": false,
      "BaseUrl": "https://api.openai.com/v1",
      "Model": "",
      "ApiKey": "",
      "TimeoutMs": 60000
    },
    "Generation": {
      "MaxTokens": 160,
      "Temperature": 0.2
    }
  },
  "RemoteConnectivity": {
    "TimeoutMs": 2000
  }
}

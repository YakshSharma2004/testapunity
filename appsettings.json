{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/dev-.log",
          "rollingInterval": "Day",
          "restrictedToMinimumLevel": "Debug",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/demo-.log",
          "rollingInterval": "Day",
          "restrictedToMinimumLevel": "Information",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "Onnx": {
    "ModelPath": "models/intent-classifier.onnx",
    "InputNames": [
      "input_ids"
    ],
    "OutputNames": [
      "logits"
    ]
  },
  "Embeddings": {
    "Model": "mpnet",
    "Models": {
      "mpnet": {
        "ModelPath": "models/mpnet/model.onnx",
        "TokenizerPath": "models/mpnet/tokenizer.json",
        "MaxLen": 384
      },
      "multiqa": {
        "ModelPath": "models/multiqa/model.onnx",
        "TokenizerPath": "models/multiqa/tokenizer.json",
        "MaxLen": 384
      }
    }
  },
  "ApiCache": {
    "IntentTtlSeconds": 120,
    "LlmTtlSeconds": 60,
    "ModelVersion": "v1"
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379,abortConnect=false,connectRetry=5,connectTimeout=5000,syncTimeout=5000"
  },
  "Redis": {
    "InstanceName": "testapi1:"
  },
  "AllowedHosts": "*",
  "IntentClassification": {
    "TopK": 3,
    "MinConfidence": 0.45,
    "IncludeDebugNotes": true
  },
  "Progression": {
    "SessionTtlMinutes": 120
  },
  "VectorStore": {
    "Provider": "Qdrant"
  },
  "Qdrant": {
    "BaseUrl": "https://4ca49af0-d23f-4270-a284-8801e44a59a9.sa-east-1-0.aws.cloud.qdrant.io",
    "CollectionName": "test_1",
    "ApiKey": ""
  }
}

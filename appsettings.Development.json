{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ApiCache": {
    "IntentTtlSeconds": 120,
    "LlmTtlSeconds": 60,
    "ModelVersion": "v1"
  },
  "Embeddings": {
    "Model": "mpnet",
    "Models": {
      "mpnet": {
        "ModelPath": "models/mpnet/model.onnx",
        "TokenizerPath": "models/mpnet/tokenizer.json",
        "MaxLen": 384
      },
      "multiqa": {
        "ModelPath": "models/multiqa/model.onnx",
        "TokenizerPath": "models/multiqa/tokenizer.json",
        "MaxLen": 384
      }
    }
  },
  "ConnectionStrings": {
    "Redis": "SET_VIA_ENV",
    "Postgres": "SET_VIA_ENV"
  },
  "Redis": {
    "InstanceName": "testapi1:"
  },
  "IntentClassification": {
    "TopK": 3,
    "MinConfidence": 0.45,
    "IncludeDebugNotes": true
  },
  "Progression": {
    "SessionTtlMinutes": 120
  },
  "VectorStore": {
    "Provider": "SET_VIA_ENV"
  },
  "Qdrant": {
    "BaseUrl": "SET_VIA_ENV",
    "CollectionName": "SET_VIA_ENV",
    "ApiKey": ""
  },
  "RemoteConnectivity": {
    "TimeoutMs": 2000
  }
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ApiCache": {
    "IntentTtlSeconds": 15,
    "LlmTtlSeconds": 60,
    "ModelVersion": "v1"
  },
  "Embeddings": {
    "Model": "mpnet",
    "Models": {
      "mpnet": {
        "ModelPath": "models/mpnet/model.onnx",
        "TokenizerPath": "models/mpnet/tokenizer.json",
        "MaxLen": 384
      },
      "multiqa": {
        "ModelPath": "models/multiqa/model.onnx",
        "TokenizerPath": "models/multiqa/tokenizer.json",
        "MaxLen": 384
      }
    }
  },
  "Redis": {
    "InstanceName": "testapi1:"
  },
  "IntentClassification": {
    "TopK": 3,
    "MinConfidence": 0.45,
    "IncludeDebugNotes": true
  },
  "Progression": {
    "SessionTtlMinutes": 120,
    "ConfessionRequiredClues": [
      "elsa_email_draft",
      "payroll_report",
      "meeting_note",
      "entry_log",
      "pin_note",
      "cleanup_item",
      "weapon_found",
      "flash_drive"
    ]
  },
  "VectorStore": {
    "Provider": "SET_VIA_ENV"
  },
  "Qdrant": {
    "BaseUrl": "SET_VIA_ENV",
    "CollectionName": "SET_VIA_ENV",
    "ApiKey": ""
  },
  "Llm": {
    "Local": {
      "Enabled": true,
      "BaseUrl": "http://localhost:11434",
      "Model": "",
      "TimeoutMs": 120000,
      "Seed": 17,
      "MaxRecentExchanges": 4,
      "MaxLoreSnippets": 3,
      "MaxTimelineItems": 3,
      "MaxPublicStoryChars": 500,
      "MaxTruthSummaryChars": 500,
      "MaxRelationshipMemoryChars": 200
    },
    "Remote": {
      "Enabled": false,
      "BaseUrl": "https://api.openai.com/v1",
      "Model": "",
      "ApiKey": "",
      "TimeoutMs": 60000
    },
    "Generation": {
      "MaxTokens": 160,
      "Temperature": 0.2
    }
  },
  "RemoteConnectivity": {
    "TimeoutMs": 2000
  }
}
